{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "purabo",
  "version": "0.1.0",
  "identifier": "app.purabo.forge",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3001",
    "beforeDevCommand": "pnpm dev --port 3001",
    "beforeBuildCommand": "pnpm build -- --no-lint"
  },
  "app": {
    "windows": [
      {
        "title": "Purabo",
        "width": 1000,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
